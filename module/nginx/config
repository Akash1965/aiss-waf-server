ngx_addon_name=ngx_http_aiss_module

if test -n "$ngx_module_link"; then
    # NGINX dynamic module build system (>= 1.9.11)
    ngx_module_type=HTTP
    ngx_module_name=ngx_http_aiss_module
    ngx_module_srcs="$ngx_addon_dir/ngx_http_aiss_module.c"
    ngx_module_deps=
    ngx_module_libs=

    . auto/module
else
    # Legacy static build
    HTTP_MODULES="$HTTP_MODULES ngx_http_aiss_module"
    NGX_ADDON_SRCS="$NGX_ADDON_SRCS $ngx_addon_dir/ngx_http_aiss_module.c"
fi
